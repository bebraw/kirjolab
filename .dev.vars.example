# Optional local overrides. `npm run dev` already uses loopback-only local
# authentication through wrangler.jsonc.
AUTH_MODE=local
ACCESS_TEAM_DOMAIN=
ACCESS_AUD=
CROSSREF_MAILTO=
OPENALEX_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=
GITHUB_APP_ID=
GITHUB_APP_SLUG=
# Set with `wrangler secret put GITHUB_APP_PRIVATE_KEY` in deployed environments.
GITHUB_APP_PRIVATE_KEY=
