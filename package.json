{
  "name": "kirjolab",
  "private": true,
  "packageManager": "npm@11.17.0",
  "engines": {
    "node": "24.15.0",
    "npm": ">=11 <12"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "onFail": "error"
    }
  },
  "vibeTemplate": {
    "updates": [
      "2026-06-09-node-24-npm-baseline",
      "2026-06-10-capability-kits",
      "2026-06-11-mutation-quality-gate",
      "2026-06-12-affected-guardrails",
      "2026-06-12-incremental-local-mutation",
      "2026-06-13-affected-unit-tests",
      "2026-06-13-github-only-mutation-ci",
      "2026-06-13-relative-stryker-concurrency",
      "2026-06-14-agent-ci-warm-cache",
      "2026-06-14-agent-sync-entrypoint",
      "2026-06-17-advisory-fallow-diagnostics",
      "2026-06-17-shared-affected-file-utils",
      "2026-07-08-typescript-7-typecheck",
      "2026-07-10-playwright-1-61-ci-image",
      "2026-07-12-remove-readme-screenshot",
      "2026-07-13-agent-ci-progress",
      "2026-07-13-agent-ci-progress-events",
      "2026-07-14-agent-ci-cache-isolation",
      "2026-07-14-scope-prettier-to-owned-files",
      "2026-07-14-prettier-content-cache",
      "2026-07-14-oxlint-correctness-gate",
      "2026-07-15-quality-gate-progress",
      "2026-07-16-keep-mutation-explicit",
      "2026-07-16-deterministic-worker-types"
    ]
  },
  "scripts": {
    "build": "npm run build:css && npm run build:client && npm run build:service-worker && npm run build:markdown-runtime && npm run build:pdf-runtime && npm run build:pdf-worker",
    "build:client": "mkdir -p ./.generated && esbuild src/client/app.ts --bundle --format=esm --target=es2022 --minify --outfile=.generated/app.txt",
    "build:css": "mkdir -p ./.generated && tailwindcss -i ./src/tailwind-input.css -o ./.generated/styles.css --minify",
    "build:model-companion": "mkdir -p ./.generated && esbuild src/model-companion.ts --bundle --platform=node --format=esm --target=node24 --outfile=.generated/model-companion.mjs",
    "build:markdown-runtime": "mkdir -p ./.generated/assets && rm -f ./.generated/assets/markdown-module-0.9.5.js ./.generated/assets/satteri_napi.wasm32-wasi.wasm ./.generated/assets/satteri-wasi-worker.mjs && esbuild src/domain/markdown.ts --bundle --format=esm --target=es2022 --minify --outfile=.generated/assets/markdown-module-1.js",
    "build:pdf-runtime": "mkdir -p ./.generated/assets && rm -f ./.generated/assets/pdfjs-module-6.1.200.js && esbuild node_modules/pdfjs-dist/legacy/build/pdf.mjs --bundle --format=esm --target=es2022 --minify --outfile=.generated/assets/pdfjs-module-6.1.200-compat-1.js",
    "build:pdf-worker": "mkdir -p ./.generated && esbuild node_modules/pdfjs-dist/legacy/build/pdf.worker.mjs --bundle --format=esm --target=es2022 --minify --outfile=.generated/pdf-worker.txt",
    "build:service-worker": "mkdir -p ./.generated && esbuild src/client/service-worker.ts --bundle --format=iife --target=es2022 --minify --outfile=.generated/service-worker.txt",
    "ci:local": "node ./scripts/run-local-ci.mjs",
    "ci:local:retry": "agent-ci retry",
    "deploy": "node ./scripts/deploy-production.mjs",
    "deploy:dry-run": "node ./scripts/deploy-production.mjs --dry-run-only",
    "dev": "node --env-file-if-exists=.env ./scripts/run-dev.mjs",
    "dev:worker": "CLOUDFLARE_LOAD_DEV_VARS_FROM_DOT_ENV=false HOME=$PWD wrangler dev --local --ip 127.0.0.1 --port 8787 --inspector-ip 127.0.0.1 --inspector-port 9229 --log-level error --show-interactive-dev-session=false",
    "diagnostics:codebase": "npm run diagnostics:readability && npm run diagnostics:health",
    "diagnostics:health": "fallow health --score --hotspots --targets --quiet --no-cache",
    "diagnostics:readability": "fallow audit --max-crap 100 --quiet --no-cache",
    "e2e": "playwright test --pass-with-no-tests",
    "e2e:server": "node ./scripts/run-e2e-server.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check . --cache --cache-strategy content --cache-location .cache/prettier",
    "lighthouse": "node ./scripts/run-lighthouse.mjs",
    "lint": "oxlint --max-warnings 0",
    "model:companion": "npm run build:model-companion && node --env-file-if-exists=.env ./.generated/model-companion.mjs",
    "mutation": "NODE_OPTIONS=--max-old-space-size=8192 stryker run",
    "mutation:incremental": "NODE_OPTIONS=--max-old-space-size=8192 stryker run --incremental --ignoreStatic",
    "playwright:install": "playwright install chromium",
    "prepare": "node ./scripts/setup-git-hooks.mjs",
    "quality:affected": "node ./scripts/run-affected-guardrails.mjs",
    "quality:gate": "node ./scripts/run-quality-gate.mjs",
    "quality:gate:fast": "npm run format:check && npm run lint && npm run worker:types:check && npm run typecheck && npm run worker:client-guard && npm run test:tooling && npm run security:audit && npm run test:coverage && npm run test:workers",
    "security:audit": "npm audit --omit=dev --audit-level high",
    "test": "vitest run --passWithNoTests",
    "test:affected": "node ./scripts/run-affected-tests.mjs",
    "test:coverage": "node ./scripts/run-coverage-gate.mjs",
    "test:tooling": "node --test scripts/run-quality-gate.test.mjs",
    "test:workers": "CLOUDFLARE_LOAD_DEV_VARS_FROM_DOT_ENV=false vitest run --config vitest.workers.config.mts",
    "typecheck": "node ./node_modules/typescript-7/bin/tsc --noEmit && node ./node_modules/typescript-7/bin/tsc --noEmit -p tsconfig.client.json && npm run typecheck:workers",
    "typecheck:workers": "node ./node_modules/typescript-7/bin/tsc --noEmit -p tsconfig.workers-test.json",
    "worker:client-guard": "node ./scripts/assert-no-worker-client-scripts.mjs",
    "worker:types": "CLOUDFLARE_LOAD_DEV_VARS_FROM_DOT_ENV=false wrangler types",
    "worker:types:check": "CLOUDFLARE_LOAD_DEV_VARS_FROM_DOT_ENV=false wrangler types --check"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.18.4",
    "@playwright/test": "1.61.1",
    "@redwoodjs/agent-ci": "0.17.1",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/typescript-checker": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@tailwindcss/cli": "4.3.1",
    "@types/node": "24.13.2",
    "@vitest/coverage-v8": "4.1.8",
    "chrome-launcher": "1.2.1",
    "esbuild": "0.28.1",
    "fallow": "2.97.0",
    "lighthouse": "13.4.0",
    "oxlint": "1.74.0",
    "prettier": "3.8.4",
    "tailwindcss": "4.3.1",
    "typescript": "npm:@typescript/typescript6@6.0.2",
    "typescript-7": "npm:typescript@7.0.2",
    "vitest": "4.1.8",
    "wrangler": "4.111.0"
  },
  "dependencies": {
    "fflate": "0.8.3",
    "pdf-lib": "1.17.1",
    "pdfjs-dist": "6.1.200",
    "rehype-sanitize": "6.0.0",
    "rehype-stringify": "10.0.1",
    "remark-directive": "4.0.0",
    "remark-frontmatter": "5.0.0",
    "remark-gfm": "4.0.1",
    "remark-parse": "11.0.0",
    "remark-rehype": "11.1.2",
    "unified": "11.0.5",
    "unist-util-visit": "5.0.0",
    "xstate": "5.32.4",
    "yjs": "13.6.31"
  }
}
