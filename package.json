{
  "name": "kirjolab",
  "private": true,
  "packageManager": "npm@11.17.0",
  "engines": {
    "node": "24.15.0",
    "npm": ">=11 <12"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "onFail": "error"
    }
  },
  "vibeTemplate": {
    "updates": [
      "2026-06-09-node-24-npm-baseline",
      "2026-06-10-capability-kits",
      "2026-06-11-mutation-quality-gate",
      "2026-06-12-affected-guardrails",
      "2026-06-12-incremental-local-mutation",
      "2026-06-13-affected-unit-tests",
      "2026-06-13-github-only-mutation-ci",
      "2026-06-13-relative-stryker-concurrency",
      "2026-06-14-agent-ci-warm-cache",
      "2026-06-14-agent-sync-entrypoint",
      "2026-06-17-advisory-fallow-diagnostics",
      "2026-06-17-shared-affected-file-utils",
      "2026-07-08-typescript-7-typecheck",
      "2026-07-10-playwright-1-61-ci-image",
      "2026-07-12-remove-readme-screenshot",
      "2026-07-13-agent-ci-progress"
    ]
  },
  "scripts": {
    "build": "npm run build:css && npm run build:client && npm run build:pdf-worker && npm run build:satteri-assets",
    "build:client": "mkdir -p ./.generated && esbuild src/client/app.ts --bundle --format=esm --target=es2022 --outfile=.generated/app.txt",
    "build:css": "mkdir -p ./.generated && tailwindcss -i ./src/tailwind-input.css -o ./.generated/styles.css --minify",
    "build:model-companion": "mkdir -p ./.generated && esbuild src/model-companion.ts --bundle --platform=node --format=esm --target=node24 --outfile=.generated/model-companion.mjs",
    "build:pdf-worker": "mkdir -p ./.generated && esbuild node_modules/pdfjs-dist/build/pdf.worker.mjs --bundle --format=esm --target=es2022 --minify --outfile=.generated/pdf-worker.txt",
    "build:satteri-assets": "mkdir -p ./.generated/assets && cp vendor/satteri-wasm32-wasi/satteri_napi.wasm32-wasi.wasm ./.generated/assets/satteri_napi.wasm32-wasi.wasm && esbuild vendor/satteri-wasm32-wasi/wasi-worker-browser.mjs --bundle --platform=browser --format=esm --target=es2022 --outfile=.generated/assets/satteri-wasi-worker.mjs",
    "ci:local": "node ./scripts/run-local-ci.mjs",
    "ci:local:retry": "agent-ci retry",
    "deploy": "node ./scripts/deploy-production.mjs",
    "deploy:dry-run": "node ./scripts/deploy-production.mjs --dry-run-only",
    "dev": "HOME=$PWD wrangler dev --local --ip 127.0.0.1 --port 8787 --inspector-ip 127.0.0.1 --inspector-port 9229 --log-level error --show-interactive-dev-session=false",
    "diagnostics:codebase": "npm run diagnostics:readability && npm run diagnostics:health",
    "diagnostics:health": "fallow health --score --hotspots --targets --quiet --no-cache",
    "diagnostics:readability": "fallow audit --max-crap 100 --quiet --no-cache",
    "e2e": "playwright test --pass-with-no-tests",
    "e2e:server": "node ./scripts/run-e2e-server.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lighthouse": "node ./scripts/run-lighthouse.mjs",
    "model:companion": "npm run build:model-companion && node ./.generated/model-companion.mjs",
    "mutation": "stryker run",
    "mutation:incremental": "stryker run --incremental",
    "playwright:install": "playwright install chromium",
    "prepare": "node ./scripts/setup-git-hooks.mjs",
    "quality:affected": "node ./scripts/run-affected-guardrails.mjs",
    "quality:gate": "npm run quality:gate:fast && npm run e2e && npm run mutation:incremental",
    "quality:gate:fast": "npm run format:check && npm run typecheck && npm run worker:client-guard && npm run security:audit && npm run test:coverage && npm run test:workers",
    "security:audit": "npm audit --omit=dev --audit-level high",
    "test": "vitest run --passWithNoTests",
    "test:affected": "node ./scripts/run-affected-tests.mjs",
    "test:coverage": "node ./scripts/run-coverage-gate.mjs",
    "test:workers": "npm run build:satteri-assets && vitest run --config vitest.workers.config.mts",
    "typecheck": "node ./node_modules/typescript-7/bin/tsc --noEmit && node ./node_modules/typescript-7/bin/tsc --noEmit -p tsconfig.client.json && npm run typecheck:workers",
    "typecheck:workers": "node ./node_modules/typescript-7/bin/tsc --noEmit -p tsconfig.workers-test.json",
    "worker:client-guard": "node ./scripts/assert-no-worker-client-scripts.mjs"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.18.4",
    "@playwright/test": "1.61.1",
    "@redwoodjs/agent-ci": "0.16.2",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/typescript-checker": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@tailwindcss/cli": "4.3.1",
    "@types/node": "24.13.2",
    "@vitest/coverage-v8": "4.1.8",
    "chrome-launcher": "1.2.1",
    "esbuild": "0.28.1",
    "fallow": "2.97.0",
    "lighthouse": "13.4.0",
    "prettier": "3.8.4",
    "tailwindcss": "4.3.1",
    "typescript": "npm:@typescript/typescript6@6.0.2",
    "typescript-7": "npm:typescript@7.0.2",
    "vitest": "4.1.8",
    "wrangler": "4.100.0"
  },
  "dependencies": {
    "@bruits/satteri-wasm32-wasi": "file:vendor/satteri-wasm32-wasi",
    "@emnapi/core": "1.11.1",
    "@emnapi/runtime": "1.11.1",
    "@napi-rs/wasm-runtime": "1.1.6",
    "fflate": "0.8.3",
    "pdf-lib": "1.17.1",
    "pdfjs-dist": "6.1.200",
    "satteri": "0.9.5",
    "yjs": "13.6.31"
  }
}
